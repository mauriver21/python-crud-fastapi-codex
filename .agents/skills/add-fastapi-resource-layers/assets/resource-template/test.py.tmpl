import pytest
from fastapi.testclient import TestClient
from sqlalchemy.pool import StaticPool
from sqlmodel import SQLModel, Session, create_engine

from {{package_name}}.db.engine import get_session
from {{package_name}}.main import app


@pytest.fixture
def client() -> TestClient:
    engine = create_engine(
        "sqlite://",
        connect_args={"check_same_thread": False},
        poolclass=StaticPool,
    )
    SQLModel.metadata.create_all(engine)

    def session_override():
        with Session(engine) as session:
            yield session

    app.dependency_overrides[get_session] = session_override
    with TestClient(app) as test_client:
        yield test_client
    app.dependency_overrides.clear()
    SQLModel.metadata.drop_all(engine)


def sample_payload() -> dict[str, object]:
    return {
{{sample_fields}}
    }


def test_crud_and_pagination(client: TestClient) -> None:
    create_response = client.post("/{{plural_name}}", json=sample_payload())
    assert create_response.status_code == 201
    body = create_response.json()
    assert "id" in body

    resource_id = body["id"]
    assert client.get(f"/{{plural_name}}/{resource_id}").status_code == 200

    list_response = client.get("/{{plural_name}}?page=1&size=10")
    assert list_response.status_code == 200
    assert list_response.json()["total"] == 1
    assert len(list_response.json()["items"]) == 1

    assert client.put(f"/{{plural_name}}/{resource_id}", json={}).status_code == 200
    assert client.delete(f"/{{plural_name}}/{resource_id}").status_code == 204
    assert client.get(f"/{{plural_name}}/{resource_id}").status_code == 404


def test_validation_and_missing_resource(client: TestClient) -> None:
    assert client.post("/{{plural_name}}", json={}).status_code == 422
    response = client.get("/{{plural_name}}/12345678-1234-5678-1234-567812345678")
    assert response.status_code == 404
